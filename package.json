{
  "name": "drawtool-monorepo",
  "private": true,
  "packageManager": "pnpm@10.28.1",
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  },
  "scripts": {
    "dev:drawtool": "pnpm --filter drawtool dev",
    "dev:writing": "pnpm --filter writing dev",
    "dev:unleashed": "pnpm --filter unleashed dev",
    "build:drawtool": "pnpm --filter drawtool build",
    "build:writing": "pnpm --filter writing build",
    "build:unleashed": "pnpm --filter unleashed build",
    "dev:homepage": "pnpm --filter homepage dev",
    "build:homepage": "pnpm --filter homepage build"
  }
}
